# gitinstall 环境变量配置
# 复制此文件为 .env 并填入实际值

# ── 服务器 ──
# GITINSTALL_HOST=127.0.0.1     # 绑定地址，生产环境用 0.0.0.0
# GITINSTALL_BASE_URL=https://gitinstall.cn  # 公网 URL（用于邮件中的链接）

# ── 管理员 ──
# GITINSTALL_ADMIN_SECRET=      # 首次设置管理员时的密钥（设置后可删除）

# ── 邮件（SMTP） ──
# GITINSTALL_SMTP_HOST=smtp.qq.com
# GITINSTALL_SMTP_PORT=465
# GITINSTALL_SMTP_USER=         # 发件邮箱
# GITINSTALL_SMTP_PASS=         # 邮箱授权码（非登录密码）

# ── LLM（可选，增强安装计划质量） ──
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GROQ_API_KEY=
# DEEPSEEK_API_KEY=
# GOOGLE_API_KEY=
